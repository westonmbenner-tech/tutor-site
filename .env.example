# Supabase — get these from your Supabase project settings
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-publishable-key

# Server-only (never expose to the client)
SUPABASE_SECRET_KEY=your-secret-key

# OpenAI — used server-side for mistake pattern analysis and homework auto grading
OPENAI_API_KEY=sk-your-openai-api-key

# Email notifications (Resend)
ADMIN_UPDATE_EMAIL=your-tutor@gmail.com
RESEND_API_KEY=re_your-resend-api-key
# Verified custom-domain sender in Resend, e.g. TutorCheck <notifications@tutor-check.com>
EMAIL_FROM=TutorCheck <notifications@tutor-check.com>
# ADMIN_UPDATE_EMAIL: tutor inbox for student/parent activity
# Student profile emails receive homework assigned + tutor homework comment alerts

# Optional site origin for non-auth links
NEXT_PUBLIC_SITE_URL=https://www.tutor-check.com
